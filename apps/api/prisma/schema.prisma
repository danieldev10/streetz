generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum AccountStatus {
  ACTIVE
  DEACTIVATED
  SUSPENDED
  BANNED
  DELETED
}

enum ModerationActionType {
  SUSPEND
  BAN
  RESTORE
  DELETE
  DEACTIVATE
  REACTIVATE
}

enum Gender {
  WOMAN
  MAN
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum Sexuality {
  STRAIGHT
  GAY
  LESBIAN
  BISEXUAL
  PANSEXUAL
  ASEXUAL
  QUEER
  PREFER_NOT_TO_SAY
}

enum ConnectionStatus {
  MEET_NOW
  FWB
  JUST_FRIENDS
  DATING
}

enum DiscoveryAction {
  LIKE
  PASS
}

enum MatchStatus {
  ACTIVE
  BLOCKED
  UNMATCHED
}

enum ReportStatus {
  OPEN
  REVIEWED
  DISMISSED
  ACTIONED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum TicketStatus {
  RESERVED
  PAID
  CHECKED_IN
  CANCELLED
  REFUNDED
}

enum PaymentPurpose {
  SUBSCRIPTION
  EVENT_TICKET
  MEMBERSHIP_EVENT_TICKET
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  ABANDONED
  REVERSED
}

enum NotificationKind {
  ROOM_CREATED
  EVENT_PUBLISHED
  MATCH_CREATED
  TICKET_CONFIRMED
  SUBSCRIPTION_EXPIRING
  REPORT_STATUS_UPDATED
  EVENT_REMINDER
  EVENT_UPDATED
  EVENT_CANCELLED
  PAYMENT_FAILED
  SUBSCRIPTION_PAYMENT_SUCCESS
}

enum FaceVerificationStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  FAILED
  REVIEW_REQUIRED
}

enum FaceVerificationProvider {
  AWS_REKOGNITION
}

model User {
  id                 String               @id @default(cuid())
  email              String               @unique
  displayName        String
  passwordHash       String
  role               UserRole             @default(USER)
  subscriptionStatus SubscriptionStatus   @default(INACTIVE)
  subscriptionEndsAt DateTime?
  accountStatus      AccountStatus        @default(ACTIVE)
  suspendedUntil     DateTime?
  deactivatedAt      DateTime?
  deletedAt          DateTime?
  moderationReason   String?
  ageConfirmedAt     DateTime?
  faceVerificationStatus         FaceVerificationStatus @default(NOT_STARTED)
  faceVerificationVerifiedAt     DateTime?
  faceVerificationOverrideReason String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  profile            Profile?
  photos             ProfilePhoto[]
  discoveryActions   DiscoveryActionLog[] @relation("DiscoveryActor")
  receivedActions    DiscoveryActionLog[] @relation("DiscoveryTarget")
  matchesA           Match[]              @relation("MatchUserA")
  matchesB           Match[]              @relation("MatchUserB")
  blockedUsers       UserBlock[]          @relation("Blocker")
  blockedByUsers     UserBlock[]          @relation("Blocked")
  reportsMade        UserReport[]         @relation("Reporter")
  reportsReceived    UserReport[]         @relation("Reported")
  directMessages     DirectMessage[]
  matchReadStates    MatchReadState[]
  chatMessages       ChatMessage[]
  createdRooms       ChatRoom[]           @relation("RoomCreator")
  roomMemberships    RoomMembership[]
  tickets            Ticket[]
  payments           Payment[]
  notificationSeens  NotificationSeen[]
  refreshTokens      RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  faceVerificationAttempts FaceVerificationAttempt[]
  moderationActionsTaken    ModerationAction[] @relation("ModerationAdmin")
  moderationActionsReceived ModerationAction[] @relation("ModerationTarget")
}

model FaceVerificationAttempt {
  id                  String                   @id @default(cuid())
  userId              String
  user                User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider            FaceVerificationProvider @default(AWS_REKOGNITION)
  providerSessionId   String?                  @unique
  status              FaceVerificationStatus   @default(PENDING)
  effectiveStatus     FaceVerificationStatus?
  livenessConfidence  Float?
  faceMatchSimilarity Float?
  matchedPhotoId      String?
  referenceImageBucket String?
  referenceImageKey   String?
  auditImagePrefix    String?
  failureReason       String?
  overrideReason      String?
  completedAt         DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model RefreshToken {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash         String    @unique
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, usedAt])
  @@index([expiresAt])
}

model Profile {
  id                     String            @id @default(cuid())
  userId                 String            @unique
  user                   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio                    String?
  birthDate              DateTime?
  gender                 Gender?
  sexuality              Sexuality?
  connectionStatus       ConnectionStatus?
  city                   String?
  state                  String?
  latitude               Float?
  longitude              Float?
  location               Unsupported("geography(Point,4326)")?
  locationAccuracyMeters Float?
  locationUpdatedAt      DateTime?
  maxDistanceKm          Int               @default(50)
  interests              String[]          @default([])
  discoveryLive          Boolean           @default(true)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@index([connectionStatus])
  @@index([latitude, longitude])
}

model ProfilePhoto {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url            String
  objectKey      String?
  thumbUrl       String?
  thumbObjectKey String?
  cardUrl        String?
  cardObjectKey  String?
  fullUrl        String?
  fullObjectKey  String?
  blurDataUrl    String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
}

model DiscoveryActionLog {
  id        String          @id @default(cuid())
  actorId   String
  targetId  String
  action    DiscoveryAction
  actor     User            @relation("DiscoveryActor", fields: [actorId], references: [id], onDelete: Cascade)
  target    User            @relation("DiscoveryTarget", fields: [targetId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())

  @@unique([actorId, targetId])
  @@index([targetId, action])
}

model Match {
  id                             String            @id @default(cuid())
  userAId                        String
  userBId                        String
  userA                          User              @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB                          User              @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)
  status                         MatchStatus       @default(ACTIVE)
  userAConnectionStatusAtMatch   ConnectionStatus?
  userBConnectionStatusAtMatch   ConnectionStatus?
  createdAt                      DateTime          @default(now())
  messages                       DirectMessage[]
  readStates MatchReadState[]

  @@unique([userAId, userBId])
}

model DirectMessage {
  id        String    @id @default(cuid())
  matchId   String
  senderId  String
  match     Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sender    User      @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([matchId, createdAt])
  @@index([senderId, createdAt])
}

model MatchReadState {
  id         String   @id @default(cuid())
  matchId    String
  userId     String
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([matchId, userId])
  @@index([userId])
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  reason    String?
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model UserReport {
  id         String       @id @default(cuid())
  reporterId String
  reportedId String
  reporter   User         @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported   User         @relation("Reported", fields: [reportedId], references: [id], onDelete: Cascade)
  reason     String
  details    String?
  status     ReportStatus @default(OPEN)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  moderationActions ModerationAction[]

  @@index([reportedId, status])
  @@index([reporterId, createdAt])
}

model ModerationAction {
  id           String               @id @default(cuid())
  adminId      String?
  targetUserId String?
  reportId     String?
  action       ModerationActionType
  reason       String?
  expiresAt    DateTime?
  createdAt    DateTime             @default(now())
  admin        User?                @relation("ModerationAdmin", fields: [adminId], references: [id], onDelete: SetNull)
  targetUser   User?                @relation("ModerationTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  report       UserReport?          @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([targetUserId, createdAt])
  @@index([reportId])
}

model ChatRoom {
  id          String           @id @default(cuid())
  name        String
  description String?
  category    String           @default("General")
  isActive    Boolean          @default(true)
  createdById String?
  createdBy   User?            @relation("RoomCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  messages    ChatMessage[]
  memberships RoomMembership[]

  @@index([isActive, updatedAt])
  @@index([createdById])
}

model ChatMessage {
  id        String    @id @default(cuid())
  roomId    String
  authorId  String
  room      ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([roomId, createdAt])
}

model RoomMembership {
  id       String   @id @default(cuid())
  roomId   String
  userId   String
  room     ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())
  lastReadAt DateTime @default(now())

  @@unique([roomId, userId])
  @@index([userId])
}

model Event {
  id                 String       @id @default(cuid())
  title              String
  slug               String       @unique
  description        String?
  coverImage         String?
  category           String
  venue              String
  state              String?
  city               String
  startsAt           DateTime
  endsAt             DateTime?
  status             EventStatus  @default(DRAFT)
  cancellationReason String?
  cancelledAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  ticketTypes        TicketType[]
  tickets            Ticket[]

  @@index([category, status, startsAt])
}

model TicketType {
  id                  String   @id @default(cuid())
  eventId             String
  event               Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name                String
  priceKobo           Int
  capacity            Int
  maxTicketsPerUser   Int      @default(4)
  soldCount           Int      @default(0)
  createdAt           DateTime @default(now())
  tickets             Ticket[]

  @@unique([eventId, name])
}

model Ticket {
  id           String       @id @default(cuid())
  eventId      String
  userId       String
  ticketTypeId String
  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticketType   TicketType   @relation(fields: [ticketTypeId], references: [id])
  code         String       @unique
  status       TicketStatus @default(RESERVED)
  checkedInAt   DateTime?
  reservedUntil DateTime?
  createdAt     DateTime     @default(now())

  @@index([eventId, status])
  @@index([status, reservedUntil])
  @@index([ticketTypeId, status, reservedUntil])
}

model Payment {
  id                String         @id @default(cuid())
  userId            String
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose           PaymentPurpose
  status            PaymentStatus  @default(PENDING)
  amountKobo        Int
  provider          String         @default("paystack")
  providerReference String         @unique
  providerMetadata  Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model NotificationSeen {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      NotificationKind
  entityId  String
  seenAt    DateTime         @default(now())
  createdAt DateTime         @default(now())

  @@unique([userId, kind, entityId])
  @@index([userId, kind])
}
